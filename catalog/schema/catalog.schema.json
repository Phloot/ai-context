{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "catalog_version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.(0[1-9]|1[0-2])\\.[1-9][0-9]*$"
    },
    "schema_version": {
      "const": 1
    }
  },
  "required": [
    "catalog_version",
    "schema_version"
  ],
  "$id": "catalog.schema.json",
  "title": "AI Context Catalog"
}
