{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "ComponentID": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "ProfileComponent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "id": {
          "$ref": "#/$defs/ComponentID"
        }
      },
      "required": [
        "enabled",
        "id"
      ]
    },
    "SemanticVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ProfileComponent"
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "$ref": "#/$defs/ComponentID"
    },
    "mode": {
      "const": "merge"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": 1
    },
    "version": {
      "$ref": "#/$defs/SemanticVersion"
    }
  },
  "required": [
    "components",
    "description",
    "id",
    "mode",
    "name",
    "schema_version",
    "version"
  ],
  "$id": "profile.schema.json",
  "title": "AI Context Profile"
}
